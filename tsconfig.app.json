{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["vite/client", "svelte", "vitest/globals", "w3c-web-serial"],

    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "paths": {
      "@src/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@components/*": ["./src/components/*"],
      "@domain/*": ["./src/domain/*"],
      "@views/*": ["./src/views/*"],
      "@panels/*": ["./src/panels/*"],
      "@transport/*": ["./src/transport/*"],
      "@spec/*": ["./spec/*"]
    }
  },
  "include": ["src", "spec"]
}
