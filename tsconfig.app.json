{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["vite/client", "svelte", "vitest/globals"],

    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "paths": {
      "@src/*": ["./src/*"],
      "@spec/*": ["./spec/*"]
    }
  },
  "include": ["src", "spec"]
}
